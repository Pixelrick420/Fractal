    :struct<Node> {
        :int a;
        :int b;
        :array<int, 10> arr;
        :struct<Node> next;
    }
    struct<Node> root = {
        a = 67,
        b = 69
        arr = [1,2,3]
    }
    struct <Node> cur = root;
    for (:int i, 0 ,5,1){
        struct<Node> node = {
            a = i,
            b = i*5
        }
        for(:int j, a,b,1){
            append(node::arr,j)
        }
        cur::next = node;
        cur = node;
    }
    cur::next = !null;
    !func traverse(struct<Node> node,array<:list,100>values)->:array{
        if (cur==!null){
            return;
        }
        !list<:int> temp = [node::a,node::b]
        append(values,temp);
        traverse(node::next,values);
    }
    !array<:list,100>values;
    traverse(root,values)
    
    
!end
