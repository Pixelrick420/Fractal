    !func hello(:int a, :float b, :list c) -> :boolean {
        :float sqrtOfB = sqrt(b);
        :float sqrtOfC = sqrt(c[0]);
        c[0] = 0.0;
        !return (sqrtOfB>sqrtOfC);
    }
