!start

    !func fibonacci(:int n) -> :int {
        !if (n <= 1) {
            !return n;
        }
        !else {
            !return fibonacci(n - 1) + fibonacci(n - 2);
        }
    }

    !func main() -> :void {
        :int x;
        print("Enter num: ");
        input("", x);
        !for (:int i, 0, x, 1) {
            print("{}\t", fibonacci(i));
        }

    }
    main();

!end
