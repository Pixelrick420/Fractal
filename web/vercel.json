{
  "functions": {
    "app/api/run": {
      "maxDuration": 15
    },
    "app/api/health": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}