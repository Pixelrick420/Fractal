!start

    !func fibonacci(:int n) -> :int {
        !if (n <= 1) {
            !return n;
        }
        !else {
            !return fibonacci(n - 1) + fibonacci(n - 2);
        }
    }

    !func main() -> :void {
        :int x;
        print("Enter x: ");
        input("", x);
        print("Fibonacci of {} is {}\n", x, fibonacci(x));
    }
    main();

!end
