!start
    :struct<Poly> {
        :list<:float> co;
        :int degree;
    };
    !func make_poly(:int degree) -> :struct<Poly> {
        :struct<Poly> p;
        p::degree = degree;
        p::co = [];
        !for (:int i, 0, degree + 1, 1) {
            append(p::co, 0.0);
        }
        !return p;
    }
    !func set_coeff(:struct<Poly> p, :int i, :float v) -> :void {
        p::co[i] = v;
    }
    !func eval_poly(:struct<Poly> p, :float x) -> :float {
        :float result = 0.0;
        :float xpow = 1.0;
        !for (:int i, 0, p::degree + 1, 1) {
            result = result + p::co[i] * xpow;
            xpow = xpow * x;
        }
        !return result;
    }
    !func add_poly(:struct<Poly> a, :struct<Poly> b) -> :struct<Poly> {
        :int deg = a::degree;
        !if (b::degree > deg) {
            deg = b::degree;
        }
        :struct<Poly> result = make_poly(deg);
        !for (:int i, 0, a::degree + 1, 1) {
            result::co[i] = result::co[i] + a::co[i];
        }
        !for (:int i, 0, b::degree + 1, 1) {
            result::co[i] = result::co[i] + b::co[i];
        }
        !return result;
    }
    !func mul_poly(:struct<Poly> a, :struct<Poly> b) -> :struct<Poly> {
        :int deg = a::degree + b::degree;
        :struct<Poly> result = make_poly(deg);
        !for (:int i, 0, a::degree + 1, 1) {
            !for (:int j, 0, b::degree + 1, 1) {
                result::co[i + j] = result::co[i + j] + a::co[i] * b::co[j];
            }
        }
        !return result;
    }
    !func derive_poly(:struct<Poly> p) -> :struct<Poly> {
        !if (p::degree == 0) {
            !return make_poly(0);
        }
        :struct<Poly> d = make_poly(p::degree - 1);
        !for (:int i, 1, p::degree + 1, 1) {
            d::co[i - 1] = :float(i) * p::co[i];
        }
        !return d;
    }
    :struct<Poly> p1 = make_poly(2);
    set_coeff(p1, 0, 1.0);
    set_coeff(p1, 1, 2.0);
    set_coeff(p1, 2, 3.0);
    :struct<Poly> p2 = make_poly(1);
    set_coeff(p2, 0, 1.0);
    set_coeff(p2, 1, -1.0);
    :struct<Poly> sum = add_poly(p1, p2);
    :struct<Poly> product = mul_poly(p1, p2);
    :struct<Poly> deriv = derive_poly(p1);
    :float at2 = eval_poly(p1, 2.0);
    :float dat2 = eval_poly(deriv, 2.0);
    print("p1(2) = {}", at2);
    print("p1'(2) = {}", dat2);
    print("(p1*p2)(1) = {}", eval_poly(product, 1.0));
!end
