!start

    !func fibonacci(:int n) -> :int {
        !if (n <= 1) {
            !return n;
        }
        !else {
            !return fibonacci(n - 1) + fibonacci(n - 2);
        }
    }

    !func main() -> :void {
        print("Fibonacci series up to 10:\n");
        !for (:int i, 0, 10, 1) {
            print("{}", fibonacci(i));
        }
    }
    main();

!end
