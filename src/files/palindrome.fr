!start
    # code here
    :array<:char, 11> s = "abcdefedcba";
    :int j = 10;
    !forr(:int i, 0, 11, 1) {
        !if (s[i] ~= s[j]) {
            print("not palindrome");
            !break;
        }
        j -= 1;
    }
    !if (j == -1) {
        print("\nPalindrome\n");
    }
    !else {
        print("\nnot palindrome\n");
    }

!end
